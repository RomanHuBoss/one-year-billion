# Базовые настройки
APP_NAME=Crypto Acceleration System 2026
APP_ENV=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cas2026

# API-ключи оператора backend. Для live заменить на длинные случайные значения.
OPERATOR_API_KEY=change-me-long-random-key
READONLY_API_KEY=change-me-readonly-key

# Торговля по умолчанию выключена.
TRADING_ENABLED=false
BYBIT_TESTNET=true
BYBIT_LIVE_CONFIRM=false
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Bybit private API timestamp gate. Не снижать без причины.
# Backend синхронизирует подпись с Bybit server time, чтобы избегать retCode=10002.
BYBIT_RECV_WINDOW_MS=8000
BYBIT_TIME_SYNC_TTL_SEC=60
BYBIT_TIME_SAFETY_MARGIN_MS=250

# Ollama/LLM может только блокировать или аннотировать риск.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Demo-режимы запрещены для live.
CAS_DEMO_MODE=false
CAS_ALLOW_DEMO_ML=false

# Live gates: включать только после paper/shadow и подписанного Go/No-Go.
CAS_ENABLE_LIVE_SUBMIT=false
CAS_REQUIRE_DB_FOR_LIVE=true
CAS_REQUIRE_LIVE_PREFLIGHT=true
CAS_REQUIRE_GO_NOGO_FOR_LIVE=true
CAS_GO_NOGO_PASS=false
CAS_LIVE_APPROVED_BY=
CAS_MIN_PAPER_DAYS=14
